# Copy this file to .env and fill in your credentials.

# --- Flask ---
# Generate a random secret key, e.g. with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-random-string

# --- Fitbit ---
# Register your app at https://dev.fitbit.com/apps/new
FITBIT_CLIENT_ID=your-fitbit-client-id
FITBIT_CLIENT_SECRET=your-fitbit-client-secret

# --- Strava ---
# Register your app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
